@page "/night/{UserName}/{DayStr}"
@rendermode InteractiveServer

@inject DashboardQueryService Query
@inject IJSRuntime JS

<PageTitle>@UserName — @DayStr</PageTitle>

@if (_loading)
{
    <p><em>Loading…</em></p>
}
else if (_detail is null)
{
    <h2>@UserName — @DayStr</h2>
    <p class="text-muted">No data found for this night.</p>
}
else
{
    @* ── Zone 1: Verdict bar ── *@
    <div class="@VerdictBg px-4 py-3 mb-3 rounded d-flex align-items-center flex-wrap gap-3">
        <div class="flex-grow-1">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1" style="opacity:0.8;">
                    <li class="breadcrumb-item"><a href="/" class="text-reset text-decoration-underline">Home</a></li>
                    <li class="breadcrumb-item"><a href="/user/@UserName" class="text-reset text-decoration-underline">@UserName</a></li>
                    <li class="breadcrumb-item active">@_detail.Day.ToString("MMM d")</li>
                </ol>
            </nav>
            <div class="fw-bold fs-5">@_detail.Day.ToString("dddd, dd MMM yyyy")</div>
            @if (!string.IsNullOrEmpty(Summary))
            {
                <div class="mt-1 fst-italic" style="opacity:0.9;">@Summary</div>
            }
        </div>
        @if (RrsVal.HasValue)
        {
            <div class="text-center ms-auto">
                <div class="display-5 fw-bold lh-1">@RrsVal</div>
                <div class="small opacity-75">RRS / 100</div>
            </div>
        }
    </div>

    @* ── Prev/next night navigation ── *@
    <div class="d-flex align-items-center gap-2 mb-4">
        @if (_prevDay.HasValue)
        {
            <a href="/night/@UserName/@_prevDay.Value.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline-secondary">‹ Prev night</a>
        }
        else
        {
            <span class="btn btn-sm btn-outline-secondary disabled">‹ Prev night</span>
        }
        <span class="flex-grow-1"></span>
        @if (_nextDay.HasValue)
        {
            <a href="/night/@UserName/@_nextDay.Value.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline-secondary">Next night ›</a>
        }
        else
        {
            <span class="btn btn-sm btn-outline-secondary disabled">Next night ›</span>
        }
    </div>

    @* ── Zone 2: Charts (before metric breakdown) ── *@
    @* ── Sleep stage timeline ── *@
    @if (!string.IsNullOrEmpty(_detail.SleepPhase5Min))
    {
        <div class="card mb-4">
            <div class="card-header text-muted small d-flex gap-4 align-items-center flex-wrap">
                <span>Sleep stages (5-min blocks)</span>
                <span><span style="color:#f0ad4e">■</span> Awake</span>
                <span><span style="color:#74b9ff">■</span> Light</span>
                <span><span style="color:#0984e3">■</span> Deep</span>
                <span><span style="color:#a29bfe">■</span> REM</span>
            </div>
            <div class="card-body p-2">
                <div style="display:flex;width:100%;height:28px;border-radius:4px;overflow:hidden;">
                    @foreach (var seg in BuildSleepStageSegments(_detail.SleepPhase5Min))
                    {
                        <div style="flex:@seg.Count;background:@seg.Color;" title="@seg.Label (@(seg.Count * 5) min)"></div>
                    }
                </div>
            </div>
        </div>
    }

    @* ── Intra-night HRV chart ── *@
    @if (_detail.HrvSeries.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header text-muted small">Intra-night HRV (5-min samples, ms)</div>
            <div class="card-body p-2">
                <ApexChart TItem="SamplePoint" Options="_hrvOpts" Height="200">
                    <ApexPointSeries TItem="SamplePoint" Items="_detail.HrvSeries" Name="HRV (ms)"
                        SeriesType="SeriesType.Line"
                        XValue="p => DateTime.SpecifyKind(p.Time.LocalDateTime, DateTimeKind.Utc)"
                        YValue="p => (decimal?)p.Value" />
                </ApexChart>
            </div>
        </div>
    }

    @* ── Intra-night HR chart ── *@
    @if (_detail.HeartRateSeries.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header text-muted small">Intra-night heart rate (5-min samples, bpm)</div>
            <div class="card-body p-2">
                <ApexChart TItem="SamplePoint" Options="_hrOpts" Height="200">
                    <ApexPointSeries TItem="SamplePoint" Items="_detail.HeartRateSeries" Name="HR (bpm)"
                        SeriesType="SeriesType.Line"
                        XValue="p => DateTime.SpecifyKind(p.Time.LocalDateTime, DateTimeKind.Utc)"
                        YValue="p => (decimal?)p.Value" />
                </ApexChart>
            </div>
        </div>
    }

    @* ── Zone 3: Custom Metrics ── *@
    @if (_metrics is not null)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header fw-semibold text-primary">Custom Metrics</div>
            <div class="card-body">

                @* RRS sits above the three collapsible sections *@
                @if (_metrics.RealRecoveryScore.HasValue)
                {
                    var rrsColor = _metrics.RealRecoveryScore.Value >= 75 ? "text-success"
                        : _metrics.RealRecoveryScore.Value >= 50 ? "text-warning" : "text-danger";
                    <div class="text-center mb-4 pb-3 border-bottom">
                        <div class="display-4 fw-bold @rrsColor">@_metrics.RealRecoveryScore.Value<small class="fs-5 text-muted"> / 100</small></div>
                        <div class="text-muted small">Real Recovery Score <a href="/metrics#rrs" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Composite: HR below 75 bpm (35 pts) + HRV avg (25 pts) + restorative sleep (25 pts) + resp rate (15 pts)">(?)</a></div>
                    </div>
                }

                @* Cardiovascular (open by default) *@
                @if (_metrics.HrAbove75Pct.HasValue || _metrics.HrSettlingMinutes.HasValue || _metrics.HrEarlyHalfAvg.HasValue)
                {
                    <details open class="mb-3">
                        <summary class="mb-2 fw-semibold text-uppercase small text-muted" style="cursor:pointer;">Cardiovascular</summary>
                        <div class="row text-center g-2 mt-1 mb-3">
                            @if (_metrics.HrAbove75Pct.HasValue)
                            {
                                var p75Color = _metrics.HrAbove75Pct.Value > 50 ? "text-danger" : _metrics.HrAbove75Pct.Value > 20 ? "text-warning" : "text-success";
                                <div class="col">
                                    <div class="fs-4 fw-bold @p75Color">@_metrics.HrAbove75Pct.Value.ToString("F1")%</div>
                                    <div class="text-muted small">HR above 75 bpm <a href="/metrics#hr75" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="% of the night HR exceeded 75 bpm — sustained sympathetic activation; the core cardiovascular recovery indicator">(?)</a></div>
                                </div>
                            }
                            @if (_metrics.HrAbove80Pct.HasValue)
                            {
                                var p80Color = _metrics.HrAbove80Pct.Value > 30 ? "text-danger" : _metrics.HrAbove80Pct.Value > 10 ? "text-warning" : "text-success";
                                <div class="col">
                                    <div class="fs-4 fw-bold @p80Color">@_metrics.HrAbove80Pct.Value.ToString("F1")%</div>
                                    <div class="text-muted small">HR above 80 bpm <a href="/metrics#hr80" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Stricter threshold: truly elevated HR. &gt;20% here is a clear concern">(?)</a></div>
                                </div>
                            }
                            @if (_metrics.HrSettlingMinutes.HasValue)
                            {
                                var settleColor = _metrics.HrSettlingMinutes.Value > 60 ? "text-danger" : _metrics.HrSettlingMinutes.Value > 30 ? "text-warning" : "text-success";
                                <div class="col">
                                    <div class="fs-4 fw-bold @settleColor">@_metrics.HrSettlingMinutes.Value min</div>
                                    <div class="text-muted small">HR settling time <a href="/metrics#settling" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Minutes from bedtime until HR first holds below 75 bpm: 3 consecutive 5-min samples all ≤75">(?)</a></div>
                                </div>
                            }
                            else if (_metrics.HrAbove75Pct.HasValue)
                            {
                                <div class="col">
                                    <div class="fs-4 fw-bold text-danger">Never</div>
                                    <div class="text-muted small">HR settling (HR never below 75) <a href="/metrics#settling" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="HR never held below 75 bpm for 3+ consecutive 5-min samples all night">(?)</a></div>
                                </div>
                            }
                        </div>
                        @if (_metrics.HrEarlyHalfAvg.HasValue && _metrics.HrLateHalfAvg.HasValue)
                        {
                            var hrShapeColor = (_metrics.HrShape == "settled" || _metrics.HrShape == "calm") ? "text-success"
                                : _metrics.HrShape == "elevated" ? "text-danger" : "text-warning";
                            var hrShapeSymbol = _metrics.HrShape switch
                            {
                                "settled"  => "↓",
                                "calm"     => "─",
                                "elevated" => "─",
                                "variable" => "↑",
                                _          => ""
                            };
                            <div class="row text-center g-2">
                                <div class="col">
                                    <div class="fs-5 fw-bold">@_metrics.HrEarlyHalfAvg.Value.ToString("F1") bpm</div>
                                    <div class="text-muted small">HR early-night avg</div>
                                </div>
                                <div class="col">
                                    <div class="fs-5 fw-bold">@_metrics.HrLateHalfAvg.Value.ToString("F1") bpm</div>
                                    <div class="text-muted small">HR late-night avg</div>
                                </div>
                                <div class="col">
                                    <div class="fs-5 fw-bold @hrShapeColor">@hrShapeSymbol @_metrics.HrShape</div>
                                    <div class="text-muted small">HR curve shape <a href="/metrics#hr-shape" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="settled↓ = was high, came down | elevated─ = stayed high | calm─ = low all night | variable↑ = rose late">(?)</a></div>
                                </div>
                            </div>
                        }
                    </details>
                }

                @* HRV (open by default) *@
                @if (_metrics.HrvBelow12Pct.HasValue || _metrics.HrvEarlyHalfAvg.HasValue)
                {
                    <details open class="mb-3">
                        <summary class="mb-2 fw-semibold text-uppercase small text-muted" style="cursor:pointer;">HRV</summary>
                        <div class="row text-center g-2 mt-1 mb-3">
                            @if (_metrics.HrvBelow12Pct.HasValue)
                            {
                                <div class="col">
                                    <div class="fs-4 fw-bold text-danger">@_metrics.HrvBelow12Pct.Value.ToString("F1")%</div>
                                    <div class="text-muted small">below 12 ms <a href="/metrics#hrv-dist" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="HRV zones: &lt;12 ms = poor recovery, 12–20 ms = moderate, &gt;20 ms = good. This shows the full distribution">(?)</a></div>
                                </div>
                            }
                            @if (_metrics.Hrv12To20Pct.HasValue)
                            {
                                <div class="col">
                                    <div class="fs-4 fw-bold text-warning">@_metrics.Hrv12To20Pct.Value.ToString("F1")%</div>
                                    <div class="text-muted small">12–20 ms</div>
                                </div>
                            }
                            @if (_metrics.HrvAbove20Pct.HasValue)
                            {
                                <div class="col">
                                    <div class="fs-4 fw-bold text-success">@_metrics.HrvAbove20Pct.Value.ToString("F1")%</div>
                                    <div class="text-muted small">above 20 ms</div>
                                </div>
                            }
                            @if (_metrics.HrvPeak.HasValue)
                            {
                                <div class="col">
                                    <div class="fs-4 fw-bold">@_metrics.HrvPeak.Value.ToString("F0") ms</div>
                                    <div class="text-muted small">HRV peak <a href="/metrics#hrv-peak" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Highest single HRV sample of the night — shows max parasympathetic capacity reached">(?)</a></div>
                                </div>
                            }
                        </div>
                        @if (_metrics.HrvEarlyHalfAvg.HasValue && _metrics.HrvLateHalfAvg.HasValue)
                        {
                            var dirColor = _metrics.HrvDirection == "improving" ? "text-success" : _metrics.HrvDirection == "declining" ? "text-danger" : "text-muted";
                            var dirSymbol = _metrics.HrvDirection == "improving" ? "↑" : _metrics.HrvDirection == "declining" ? "↓" : "→";
                            <div class="row text-center g-2">
                                <div class="col">
                                    <div class="fs-5 fw-bold">@_metrics.HrvEarlyHalfAvg.Value.ToString("F1") ms</div>
                                    <div class="text-muted small">HRV early-night avg</div>
                                </div>
                                <div class="col">
                                    <div class="fs-5 fw-bold">@_metrics.HrvLateHalfAvg.Value.ToString("F1") ms</div>
                                    <div class="text-muted small">HRV late-night avg</div>
                                </div>
                                <div class="col">
                                    <div class="fs-5 fw-bold @dirColor">@dirSymbol @_metrics.HrvDirection</div>
                                    <div class="text-muted small">HRV direction <a href="/metrics#hrv-dir" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Trend across the night: improving = late &gt; early by &gt;2 ms. A good night has HRV rising as sleep deepens">(?)</a></div>
                                </div>
                            </div>
                        }
                    </details>
                }

                @* Sleep Quality (open by default) *@
                @if (_metrics.RestorativeMinutes.HasValue || _metrics.AwakePctOfBed.HasValue || _detail.Efficiency.HasValue)
                {
                    <details open>
                        <summary class="mb-2 fw-semibold text-uppercase small text-muted" style="cursor:pointer;">Sleep Quality</summary>
                        <div class="row text-center g-2 mt-1">
                            @if (_metrics.RestorativeMinutes.HasValue)
                            {
                                var restColor = _metrics.RestorativeMinutes.Value >= 150 ? "text-success" : _metrics.RestorativeMinutes.Value >= 90 ? "text-warning" : "text-danger";
                                <div class="col">
                                    <div class="fs-4 fw-bold @restColor">@FmtMin(_metrics.RestorativeMinutes)</div>
                                    <div class="text-muted small">Restorative sleep (Deep + REM) <a href="/metrics#restorative" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Deep + REM combined. Target: ≥150 min = good, ≥90 min = moderate, &lt;90 min = poor">(?)</a></div>
                                </div>
                            }
                            @if (_metrics.AwakePctOfBed.HasValue)
                            {
                                var awakePctColor = _metrics.AwakePctOfBed.Value > 20 ? "text-danger" : _metrics.AwakePctOfBed.Value > 10 ? "text-warning" : "text-success";
                                <div class="col">
                                    <div class="fs-4 fw-bold @awakePctColor">@_metrics.AwakePctOfBed.Value.ToString("F1")%</div>
                                    <div class="text-muted small">Awake % of time in bed <a href="/metrics#awake-time" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Duration-independent: &lt;10% = good, 10–20% = moderate, &gt;20% = high fragmentation. More honest than efficiency %">(?)</a></div>
                                </div>
                            }
                            @if (_detail.Efficiency.HasValue)
                            {
                                var effColor = _detail.Efficiency.Value >= 90 ? "text-success" : _detail.Efficiency.Value >= 80 ? "text-warning" : "text-danger";
                                <div class="col">
                                    <div class="fs-4 fw-bold @effColor">@_detail.Efficiency.Value%</div>
                                    <div class="text-muted small">Efficiency <a href="/metrics#efficiency" class="text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Sleep ÷ time-in-bed × 100%. 90% on 5h vs 9h is very different — the percentage hides the duration">(?)</a></div>
                                </div>
                            }
                        </div>
                    </details>
                }

            </div>
        </div>
    }

    @* ── Zone 4: Oura's calculated scores (collapsed) ── *@
    @if (HasOuraData)
    {
        <details class="mb-3">
            <summary class="btn btn-sm btn-outline-secondary mb-3" style="cursor:pointer; display:list-item; list-style:none;">Oura's calculated scores</summary>
            <div class="card mb-2">
                <div class="card-body">
                    <div class="row text-center mb-3 g-2">
                        <div class="col"><div class="fs-3 fw-bold">@Fmt(_detail.SleepScore)</div><div class="text-muted small">Sleep score</div></div>
                        <div class="col"><div class="fs-3 fw-bold">@Fmt(_detail.ReadinessScore)</div><div class="text-muted small">Readiness</div></div>
                        <div class="col"><div class="fs-3 fw-bold">@Fmt(_detail.AverageHrv)</div><div class="text-muted small">HRV avg (ms)</div></div>
                        <div class="col"><div class="fs-3 fw-bold">@FmtD(_detail.AverageHeartRate)</div><div class="text-muted small">Avg HR (bpm)</div></div>
                        <div class="col"><div class="fs-3 fw-bold">@Fmt(_detail.LowestHeartRate)</div><div class="text-muted small">Lowest HR</div></div>
                        <div class="col"><div class="fs-3 fw-bold">@FmtD(_detail.AverageBreath)</div><div class="text-muted small">Resp (brpm)</div></div>
                        <div class="col"><div class="fs-3 fw-bold">@FmtTemp(_detail.TempDeviation)</div><div class="text-muted small">Temp dev</div></div>
                    </div>
                    <div class="row text-center mb-3 g-2">
                        <div class="col"><div class="fs-5 fw-bold">@Fmt(_detail.DeepMinutes)</div><div class="text-muted small">Deep (min)</div></div>
                        <div class="col"><div class="fs-5 fw-bold">@Fmt(_detail.RemMinutes)</div><div class="text-muted small">REM (min)</div></div>
                        <div class="col"><div class="fs-5 fw-bold">@Fmt(_detail.AwakeMinutes)</div><div class="text-muted small">Awake (min)</div></div>
                        @if (_detail.BedtimeStart.HasValue && _detail.BedtimeEnd.HasValue)
                        {
                            <div class="col">
                                <div class="fs-5 fw-bold">@_detail.BedtimeStart.Value.ToLocalTime().ToString("HH:mm") – @_detail.BedtimeEnd.Value.ToLocalTime().ToString("HH:mm")</div>
                                <div class="text-muted small">Bedtime window</div>
                            </div>
                        }
                        <div class="col"><div class="fs-5 fw-bold">@FmtMin(_detail.TotalSleepMinutes)</div><div class="text-muted small">Total sleep</div></div>
                        <div class="col"><div class="fs-5 fw-bold">@FmtMin(_detail.LightSleepMinutes)</div><div class="text-muted small">Light (min)</div></div>
                        <div class="col"><div class="fs-5 fw-bold">@FmtMin(_detail.TimeInBedMinutes)</div><div class="text-muted small">Time in bed</div></div>
                        <div class="col"><div class="fs-5 fw-bold">@FmtMin(_detail.LatencyMinutes)</div><div class="text-muted small">Sleep latency</div></div>
                        <div class="col"><div class="fs-5 fw-bold">@(_detail.RestlessPeriods?.ToString() ?? "—")</div><div class="text-muted small">Restless periods</div></div>
                        @if (_detail.TempTrendDeviation.HasValue)
                        {
                            <div class="col">
                                <div class="fs-5 fw-bold @(_detail.TempTrendDeviation >= 0 ? "text-warning" : "text-info")">@((_detail.TempTrendDeviation >= 0 ? "+" : "") + _detail.TempTrendDeviation.Value.ToString("F2")) °C</div>
                                <div class="text-muted small">Temp trend</div>
                            </div>
                        }
                    </div>
                    @if (_detail.SleepDeepContributor.HasValue || _detail.SleepEfficiencyContributor.HasValue)
                    {
                        <div class="mb-2 text-muted small fw-semibold">Sleep contributors</div>
                        <div class="row g-2 mb-3">
                            @foreach (var c in GetSleepContribItems(_detail))
                            {
                                <div class="col-auto">
                                    <div class="border rounded text-center px-2 py-1">
                                        <div class="fw-bold">@c.Value</div>
                                        <div class="text-muted" style="font-size:0.72rem">@c.Label</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    @if (_detail.ReadinessHrvBalance.HasValue || _detail.ReadinessRhr.HasValue)
                    {
                        <div class="mb-2 text-muted small fw-semibold">Readiness contributors</div>
                        <div class="row g-2">
                            @foreach (var c in GetReadinessContribItems(_detail))
                            {
                                <div class="col-auto">
                                    <div class="border rounded text-center px-2 py-1">
                                        <div class="fw-bold">@c.Value</div>
                                        <div class="text-muted" style="font-size:0.72rem">@c.Label</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </details>
    }

    @* ── Zone 5: Daytime context (collapsed) ── *@
    @if (_detail.Steps.HasValue || _detail.Spo2Average.HasValue
        || _detail.StressHighSec.HasValue || _detail.ResilienceLevel is not null)
    {
        <details class="mb-3">
            <summary class="btn btn-sm btn-outline-secondary mb-3" style="cursor:pointer; display:list-item; list-style:none;">Daytime context</summary>
            <div class="card mb-2">
                <div class="card-body">
                    <div class="row text-center g-3">
                        @foreach (var item in GetDaytimeItems(_detail))
                        {
                            <div class="col-6 col-md-3">
                                <div class="fs-5 fw-bold">@item.Value</div>
                                <div class="text-muted small">@item.Label</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </details>
    }

    @* ── Zone 6: Raw data (collapsed) ── *@
    <details class="mb-3">
        <summary class="btn btn-sm btn-outline-secondary mb-3" style="cursor:pointer; display:list-item; list-style:none;">Raw data — copy to LLM</summary>
        <div class="card">
            <div class="card-body p-2 d-flex flex-column gap-2">
                <button class="btn btn-sm btn-outline-primary align-self-end" @onclick="CopyToClipboard">Copy</button>
                <textarea @ref="_textareaRef" class="form-control font-monospace" style="font-size:0.78rem" rows="18" readonly>@_llmText</textarea>
            </div>
        </div>
    </details>
}

@code {
    [Parameter] public string UserName { get; set; } = string.Empty;
    [Parameter] public string DayStr  { get; set; } = string.Empty;

    private bool _loading = true;
    private NightData? _detail;
    private DateOnly? _prevDay;
    private DateOnly? _nextDay;
    private string _llmText = string.Empty;
    private NightMetrics? _metrics;
    private ApexChartOptions<SamplePoint> _hrvOpts = null!;
    private ApexChartOptions<SamplePoint> _hrOpts  = null!;
    private ElementReference _textareaRef;

    private int?   RrsVal    => _metrics?.RealRecoveryScore;
    private string VerdictBg => RrsVal.HasValue
        ? RrsVal.Value >= 75 ? "bg-success text-white"
        : RrsVal.Value >= 50 ? "bg-warning text-dark"
        : "bg-danger text-white"
        : "bg-secondary text-white";
    private string Summary   => _metrics is not null ? GenerateSummary(_detail!, _metrics) : string.Empty;
    private bool   HasOuraData => _detail is not null && (_detail.SleepScore.HasValue
        || _detail.ReadinessScore.HasValue || _detail.AverageHrv.HasValue
        || _detail.SleepDeepContributor.HasValue || _detail.ReadinessHrvBalance.HasValue);

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        if (!DateOnly.TryParse(DayStr, out var day))
        {
            _loading = false;
            return;
        }

        _detail = await Query.GetNightDetailAsync(UserName, day);

        // Build prev/next navigation from available nights
        var nights = await Query.GetNightDaysAsync(UserName, 90);
        var idx = nights.IndexOf(day);
        _nextDay = idx > 0             ? nights[idx - 1] : (DateOnly?)null; // list is DESC
        _prevDay = idx < nights.Count - 1 ? nights[idx + 1] : (DateOnly?)null;

        // Base options shared by both timeseries charts
        static ApexChartOptions<SamplePoint> BaseOpts() => new()
        {
            Chart   = new Chart { Toolbar = new Toolbar { Show = false }, Background = "transparent" },
            Stroke  = new Stroke { Curve = Curve.Smooth, Width = [1] },
            Markers = new Markers { Size = [0] },
            Grid    = new Grid { BorderColor = "#e0e0e0", Row = new GridRow { Opacity = 0 } },
            Tooltip = new Tooltip { X = new TooltipX { Format = "HH:mm" } },
            Xaxis   = new XAxis { Type = XAxisType.Datetime, Labels = new XAxisLabels { Format = "HH:mm" } },
            Yaxis   = [new YAxis { Labels = new YAxisLabels { MinWidth = 30 } }],
            Legend  = new Legend { Show = false },
        };

        // HRV chart — annotate Oura's average HRV and the 12 / 20 ms zone thresholds
        _hrvOpts = BaseOpts();
        _hrvOpts.Annotations = new Annotations { Yaxis = [] };
        if (_detail?.AverageHrv is int avgHrv)
            _hrvOpts.Annotations.Yaxis.Add(new AnnotationsYAxis
            {
                Y           = avgHrv,
                BorderColor = "#636e72",
                BorderWidth = 2,
                Label       = new Label { Text = $"Oura avg ({avgHrv} ms)",
                              Style = new Style { Background = "#636e72", Color = "#fff", FontSize = "11px" } },
            });
        _hrvOpts.Annotations.Yaxis.Add(new AnnotationsYAxis
        {
            Y = 20, BorderColor = "#00b894", BorderWidth = 1, StrokeDashArray = 4,
            Label = new Label { Text = "20 ms", Style = new Style { Background = "#00b894", Color = "#fff", FontSize = "10px" } },
        });
        _hrvOpts.Annotations.Yaxis.Add(new AnnotationsYAxis
        {
            Y = 12, BorderColor = "#e17055", BorderWidth = 1, StrokeDashArray = 4,
            Label = new Label { Text = "12 ms", Style = new Style { Background = "#e17055", Color = "#fff", FontSize = "10px" } },
        });

        // HR chart — annotate Oura's avg & lowest HR plus the 75 / 80 bpm thresholds
        _hrOpts = BaseOpts();
        _hrOpts.Annotations = new Annotations { Yaxis = [] };
        if (_detail?.AverageHeartRate is double avgHr)
            _hrOpts.Annotations.Yaxis.Add(new AnnotationsYAxis
            {
                Y           = (decimal)avgHr,
                BorderColor = "#636e72",
                BorderWidth = 2,
                Label       = new Label { Text = $"Oura avg ({avgHr:F1} bpm)",
                              Style = new Style { Background = "#636e72", Color = "#fff", FontSize = "11px" } },
            });
        if (_detail?.LowestHeartRate is int lowestHr)
            _hrOpts.Annotations.Yaxis.Add(new AnnotationsYAxis
            {
                Y           = lowestHr,
                BorderColor = "#0984e3",
                BorderWidth = 2,
                Label       = new Label { Text = $"Oura lowest ({lowestHr} bpm)",
                              Style = new Style { Background = "#0984e3", Color = "#fff", FontSize = "11px" } },
            });
        _hrOpts.Annotations.Yaxis.Add(new AnnotationsYAxis
        {
            Y = 80, BorderColor = "#e17055", BorderWidth = 1, StrokeDashArray = 4,
            Label = new Label { Text = "80 bpm", Style = new Style { Background = "#e17055", Color = "#fff", FontSize = "10px" } },
        });
        _hrOpts.Annotations.Yaxis.Add(new AnnotationsYAxis
        {
            Y = 75, BorderColor = "#fdcb6e", BorderWidth = 1, StrokeDashArray = 4,
            Label = new Label { Text = "75 bpm", Style = new Style { Background = "#fdcb6e", Color = "#000", FontSize = "10px" } },
        });

        // X-axis range and bedtime annotations (for both charts)
        if (_detail?.BedtimeStart.HasValue == true && _detail.BedtimeEnd.HasValue == true)
        {
            var xMin = ChartMs(_detail.BedtimeStart.Value.AddHours(-1));
            var xMax = ChartMs(_detail.BedtimeEnd.Value.AddHours(1));

            var bedAnnotations = new List<AnnotationsXAxis>
            {
                new AnnotationsXAxis
                {
                    X           = ChartMs(_detail.BedtimeStart.Value),
                    BorderColor = "#2d3436",
                    BorderWidth = 2,
                    Label       = new Label { Text = "Sleep", Style = new Style { Background = "#2d3436", Color = "#fff", FontSize = "10px" } },
                },
                new AnnotationsXAxis
                {
                    X           = ChartMs(_detail.BedtimeEnd.Value),
                    BorderColor = "#6c5ce7",
                    BorderWidth = 2,
                    Label       = new Label { Text = "Wake", Style = new Style { Background = "#6c5ce7", Color = "#fff", FontSize = "10px" } },
                },
            };

            _hrvOpts.Xaxis = new XAxis { Type = XAxisType.Datetime, Labels = new XAxisLabels { Format = "HH:mm" }, Min = xMin, Max = xMax };
            _hrOpts.Xaxis  = new XAxis { Type = XAxisType.Datetime, Labels = new XAxisLabels { Format = "HH:mm" }, Min = xMin, Max = xMax };
            _hrvOpts.Annotations.Xaxis = bedAnnotations;
            _hrOpts.Annotations.Xaxis  = bedAnnotations;
        }

        if (_detail is not null)
        {
            _metrics = NightMetricsCalculator.Compute(_detail);
            _llmText  = BuildLlmText(_detail);
        }

        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loading)
            await JS.InvokeVoidAsync("initTooltips");
    }

    private async Task CopyToClipboard()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _llmText);
    }

    // Encode a DateTimeOffset as "local wall-clock time treated as UTC" so ApexCharts
    // (which runs in datetimeUTC mode) displays the correct local HH:mm labels.
    private static long ChartMs(DateTimeOffset dto) =>
        new DateTimeOffset(DateTime.SpecifyKind(dto.ToLocalTime().DateTime, DateTimeKind.Utc))
            .ToUnixTimeMilliseconds();

    private static string BuildLlmText(NightData d)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"=== Oura Night Data: {d.UserName}, {d.Day:yyyy-MM-dd} ({d.Day:dddd}) ===");
        sb.AppendLine();

        if (d.BedtimeStart.HasValue && d.BedtimeEnd.HasValue)
        {
            sb.AppendLine("SLEEP WINDOW");
            sb.AppendLine($"  Bedtime      : {d.BedtimeStart.Value.ToLocalTime():HH:mm} – {d.BedtimeEnd.Value.ToLocalTime():HH:mm}");
            sb.AppendLine();
        }

        sb.AppendLine("SCORES");
        sb.AppendLine($"  Sleep score  : {d.SleepScore?.ToString() ?? "N/A"}");
        sb.AppendLine($"  Readiness    : {d.ReadinessScore?.ToString() ?? "N/A"}");
        sb.AppendLine($"  Temp dev     : {(d.TempDeviation.HasValue ? (d.TempDeviation >= 0 ? "+" : "") + d.TempDeviation.Value.ToString("F2") + " °C" : "N/A")}");
        sb.AppendLine($"  Temp trend   : {(d.TempTrendDeviation.HasValue ? (d.TempTrendDeviation >= 0 ? "+" : "") + d.TempTrendDeviation.Value.ToString("F2") + " °C" : "N/A")}");
        sb.AppendLine();

        sb.AppendLine("HEART RATE & HRV");
        sb.AppendLine($"  Avg HRV      : {(d.AverageHrv.HasValue ? d.AverageHrv + " ms" : "N/A")}");
        sb.AppendLine($"  Avg HR       : {(d.AverageHeartRate.HasValue ? d.AverageHeartRate.Value.ToString("F1") + " bpm" : "N/A")}");
        sb.AppendLine($"  Lowest HR    : {(d.LowestHeartRate.HasValue ? d.LowestHeartRate + " bpm" : "N/A")}");
        sb.AppendLine($"  Resp rate    : {(d.AverageBreath.HasValue ? d.AverageBreath.Value.ToString("F1") + " brpm" : "N/A")}");
        sb.AppendLine();

        sb.AppendLine("SLEEP STAGES");
        sb.AppendLine($"  Deep sleep   : {(d.DeepMinutes.HasValue ? d.DeepMinutes + " min" : "N/A")}");
        sb.AppendLine($"  REM sleep    : {(d.RemMinutes.HasValue ? d.RemMinutes + " min" : "N/A")}");
        sb.AppendLine($"  Light sleep  : {(d.LightSleepMinutes.HasValue ? d.LightSleepMinutes + " min" : "N/A")}");
        sb.AppendLine($"  Awake        : {(d.AwakeMinutes.HasValue ? d.AwakeMinutes + " min" : "N/A")}");
        sb.AppendLine($"  Total sleep  : {(d.TotalSleepMinutes.HasValue ? d.TotalSleepMinutes + " min" : "N/A")}");
        sb.AppendLine($"  Time in bed  : {(d.TimeInBedMinutes.HasValue ? d.TimeInBedMinutes + " min" : "N/A")}");
        sb.AppendLine($"  Efficiency   : {(d.Efficiency.HasValue ? d.Efficiency + "%" : "N/A")}");
        sb.AppendLine($"  Latency      : {(d.LatencyMinutes.HasValue ? d.LatencyMinutes + " min" : "N/A")}");
        sb.AppendLine($"  Restless     : {(d.RestlessPeriods.HasValue ? d.RestlessPeriods + " periods" : "N/A")}");

        if (!string.IsNullOrEmpty(d.SleepPhase5Min))
        {
            var awakeMin = d.SleepPhase5Min.Count(c => c == '1') * 5;
            var lightMin  = d.SleepPhase5Min.Count(c => c == '2') * 5;
            var deepMin   = d.SleepPhase5Min.Count(c => c == '3') * 5;
            var remMin    = d.SleepPhase5Min.Count(c => c == '4') * 5;
            sb.AppendLine($"  Stage breakdown (5-min res): awake={awakeMin}min light={lightMin}min deep={deepMin}min rem={remMin}min");
        }
        sb.AppendLine();

        if (d.SleepDeepContributor.HasValue || d.SleepEfficiencyContributor.HasValue)
        {
            sb.AppendLine("SLEEP SCORE CONTRIBUTORS");
            if (d.SleepDeepContributor.HasValue)        sb.AppendLine($"  Deep sleep   : {d.SleepDeepContributor}");
            if (d.SleepEfficiencyContributor.HasValue)  sb.AppendLine($"  Efficiency   : {d.SleepEfficiencyContributor}");
            if (d.SleepLatencyContributor.HasValue)     sb.AppendLine($"  Latency      : {d.SleepLatencyContributor}");
            if (d.SleepRemContributor.HasValue)         sb.AppendLine($"  REM          : {d.SleepRemContributor}");
            if (d.SleepRestfulnessContributor.HasValue) sb.AppendLine($"  Restfulness  : {d.SleepRestfulnessContributor}");
            if (d.SleepTimingContributor.HasValue)      sb.AppendLine($"  Timing       : {d.SleepTimingContributor}");
            if (d.SleepTotalContributor.HasValue)       sb.AppendLine($"  Total sleep  : {d.SleepTotalContributor}");
            sb.AppendLine();
        }

        if (d.ReadinessHrvBalance.HasValue || d.ReadinessRhr.HasValue)
        {
            sb.AppendLine("READINESS SCORE CONTRIBUTORS");
            if (d.ReadinessActivityBalance.HasValue)  sb.AppendLine($"  Activity bal : {d.ReadinessActivityBalance}");
            if (d.ReadinessBodyTemp.HasValue)         sb.AppendLine($"  Body temp    : {d.ReadinessBodyTemp}");
            if (d.ReadinessHrvBalance.HasValue)       sb.AppendLine($"  HRV balance  : {d.ReadinessHrvBalance}");
            if (d.ReadinessPrevDayActivity.HasValue)  sb.AppendLine($"  Prev day act : {d.ReadinessPrevDayActivity}");
            if (d.ReadinessPrevNight.HasValue)        sb.AppendLine($"  Prev night   : {d.ReadinessPrevNight}");
            if (d.ReadinessRecoveryIndex.HasValue)    sb.AppendLine($"  Recovery idx : {d.ReadinessRecoveryIndex}");
            if (d.ReadinessRhr.HasValue)              sb.AppendLine($"  Resting HR   : {d.ReadinessRhr}");
            if (d.ReadinessSleepBalance.HasValue)     sb.AppendLine($"  Sleep balance: {d.ReadinessSleepBalance}");
            sb.AppendLine();
        }

        var hasDayData = d.Steps.HasValue || d.Spo2Average.HasValue || d.StressHighSec.HasValue || d.ResilienceLevel is not null;
        if (hasDayData)
        {
            sb.AppendLine("DAYTIME CONTEXT");
            if (d.Steps.HasValue)                       sb.AppendLine($"  Steps        : {d.Steps.Value:N0}");
            if (d.ActiveCalories.HasValue)              sb.AppendLine($"  Active kcal  : {d.ActiveCalories}");
            if (d.Spo2Average.HasValue)                 sb.AppendLine($"  SpO2 avg     : {d.Spo2Average.Value:F1}%");
            if (d.BreathingDisturbanceIndex.HasValue)   sb.AppendLine($"  Breathing DI : {d.BreathingDisturbanceIndex}");
            if (d.StressHighSec.HasValue)               sb.AppendLine($"  High stress  : {d.StressHighSec.Value / 60} min");
            if (d.RecoveryHighSec.HasValue)             sb.AppendLine($"  High recovery: {d.RecoveryHighSec.Value / 60} min");
            if (d.ResilienceLevel is not null)          sb.AppendLine($"  Resilience   : {d.ResilienceLevel}");
            if (d.ResilienceSleepRecovery.HasValue)     sb.AppendLine($"  Sleep recov  : {d.ResilienceSleepRecovery.Value:F2}");
            if (d.ResilienceDaytimeRecovery.HasValue)   sb.AppendLine($"  Day recov    : {d.ResilienceDaytimeRecovery.Value:F2}");
            sb.AppendLine();
        }

        if (d.HrvSeries.Count > 0)
        {
            sb.AppendLine("INTRA-NIGHT HRV (5-min intervals, ms — null = no signal)");
            sb.Append("  ");
            sb.AppendLine(string.Join(", ", d.HrvSeries.Select(p =>
                $"{p.Time.ToLocalTime():HH:mm}={p.Value?.ToString("F0") ?? "null"}")));
        }

        if (d.HeartRateSeries.Count > 0)
        {
            sb.AppendLine();
            sb.AppendLine("INTRA-NIGHT HEART RATE (5-min intervals, bpm — null = no signal)");
            sb.Append("  ");
            sb.AppendLine(string.Join(", ", d.HeartRateSeries.Select(p =>
                $"{p.Time.ToLocalTime():HH:mm}={p.Value?.ToString("F0") ?? "null"}")));
        }

        return sb.ToString();
    }

    private static string Fmt(int? v)        => v.HasValue ? v.Value.ToString() : "—";
    private static string FmtD(double? v)    => v.HasValue ? v.Value.ToString("F1") : "—";
    private static string FmtTemp(double? v) => v.HasValue ? (v.Value >= 0 ? "+" : "") + v.Value.ToString("F2") + " °C" : "—";
    private static string FmtMin(int? minutes) => minutes.HasValue
        ? minutes.Value >= 60 ? $"{minutes.Value / 60}h {minutes.Value % 60}m" : $"{minutes.Value} min"
        : "—";

    private record SleepStageSegment(int Count, string Color, string Label);

    private static IEnumerable<SleepStageSegment> BuildSleepStageSegments(string phase)
    {
        var i = 0;
        while (i < phase.Length)
        {
            var ch = phase[i];
            var count = 0;
            while (i < phase.Length && phase[i] == ch) { count++; i++; }
            var (color, label) = ch switch
            {
                '1' => ("#f0ad4e", "Awake"),
                '2' => ("#74b9ff", "Light"),
                '3' => ("#0984e3", "Deep"),
                '4' => ("#a29bfe", "REM"),
                _   => ("#e0e0e0", "Unknown"),
            };
            yield return new SleepStageSegment(count, color, label);
        }
    }

    private static IEnumerable<(string Label, string? Value)> GetDaytimeItems(NightData d)
    {
        if (d.Steps.HasValue)                     yield return ("Steps",            d.Steps.Value.ToString("N0"));
        if (d.ActiveCalories.HasValue)            yield return ("Active kcal",      d.ActiveCalories.ToString()!);
        if (d.Spo2Average.HasValue)               yield return ("SpO2 avg",         d.Spo2Average.Value.ToString("F1") + "%");
        if (d.BreathingDisturbanceIndex.HasValue) yield return ("Breathing dist. idx", d.BreathingDisturbanceIndex.ToString()!);
        if (d.StressHighSec.HasValue)             yield return ("High stress",      (d.StressHighSec.Value / 60) + " min");
        if (d.RecoveryHighSec.HasValue)           yield return ("High recovery",    (d.RecoveryHighSec.Value / 60) + " min");
        if (d.ResilienceLevel is not null)        yield return ("Resilience",       d.ResilienceLevel);
        if (d.ResilienceSleepRecovery.HasValue)   yield return ("Sleep recovery",   d.ResilienceSleepRecovery.Value.ToString("F2"));
        if (d.ResilienceDaytimeRecovery.HasValue) yield return ("Daytime recovery", d.ResilienceDaytimeRecovery.Value.ToString("F2"));
    }

    private static IEnumerable<(string Label, int? Value)> GetSleepContribItems(NightData d)
    {
        if (d.SleepDeepContributor.HasValue)        yield return ("Deep",        d.SleepDeepContributor);
        if (d.SleepEfficiencyContributor.HasValue)  yield return ("Efficiency",  d.SleepEfficiencyContributor);
        if (d.SleepLatencyContributor.HasValue)     yield return ("Latency",     d.SleepLatencyContributor);
        if (d.SleepRemContributor.HasValue)         yield return ("REM",         d.SleepRemContributor);
        if (d.SleepRestfulnessContributor.HasValue) yield return ("Restfulness", d.SleepRestfulnessContributor);
        if (d.SleepTimingContributor.HasValue)      yield return ("Timing",      d.SleepTimingContributor);
        if (d.SleepTotalContributor.HasValue)       yield return ("Total sleep", d.SleepTotalContributor);
    }

    private static IEnumerable<(string Label, int? Value)> GetReadinessContribItems(NightData d)
    {
        if (d.ReadinessActivityBalance.HasValue)  yield return ("Activity balance", d.ReadinessActivityBalance);
        if (d.ReadinessBodyTemp.HasValue)         yield return ("Body temp",        d.ReadinessBodyTemp);
        if (d.ReadinessHrvBalance.HasValue)       yield return ("HRV balance",      d.ReadinessHrvBalance);
        if (d.ReadinessPrevDayActivity.HasValue)  yield return ("Prev day activity",d.ReadinessPrevDayActivity);
        if (d.ReadinessPrevNight.HasValue)        yield return ("Prev night",       d.ReadinessPrevNight);
        if (d.ReadinessRecoveryIndex.HasValue)    yield return ("Recovery index",   d.ReadinessRecoveryIndex);
        if (d.ReadinessRhr.HasValue)              yield return ("Resting HR",       d.ReadinessRhr);
        if (d.ReadinessSleepBalance.HasValue)     yield return ("Sleep balance",    d.ReadinessSleepBalance);
    }

    private static string GenerateSummary(NightData d, NightMetrics m)
    {
        var rrs = m.RealRecoveryScore;
        if (!rrs.HasValue) return string.Empty;

        if (rrs.Value >= 75)
        {
            if (m.HrvDirection == "improving" && m.HrSettlingMinutes is <= 30)
                return "Strong night — HRV improving all night, HR fully settled within 30 min.";
            if (m.HrvDirection == "improving")
                return "Strong night — HRV trended upward through the night.";
            if (m.HrShape == "calm")
                return "Strong night — HR calm from the start, good parasympathetic tone.";
            if (m.RestorativeMinutes is >= 150)
                return $"Strong night — {m.RestorativeMinutes} min of restorative sleep.";
            return "Strong recovery across all metrics.";
        }

        if (rrs.Value >= 50)
        {
            if (m.HrAbove75Pct is > 40)
                return $"Moderate recovery — HR elevated for {m.HrAbove75Pct.Value:F0}% of the night.";
            if (m.HrvDirection == "declining")
                return "Moderate recovery — HRV declined through the second half of the night.";
            if (m.RestorativeMinutes is < 90)
                return $"Moderate recovery — only {m.RestorativeMinutes} min of restorative sleep.";
            return "Moderate recovery night.";
        }

        // RRS < 50
        if (m.HrAbove75Pct is > 50)
        {
            var suffix = d.TempDeviation is > 0.3
                ? $" — temp elevated ({d.TempDeviation.Value:+F2}°C)."
                : ".";
            return $"Elevated HR for {m.HrAbove75Pct.Value:F0}% of the night{suffix}";
        }
        if (m.HrvBelow12Pct is > 50)
            return $"Poor HRV night — {m.HrvBelow12Pct.Value:F0}% of samples below 12 ms.";
        if (m.RestorativeMinutes is < 60)
            return "Poor restorative sleep — check for sleep fragmentation.";
        return "Difficult night — recovery was poor across multiple metrics.";
    }
}
