@* One card per user: key stat summary + sleep score sparkline + HRV line chart *@

@* ApexCharts needs InteractiveServer, inherited from the parent page *@

<div class="card h-100">
    <div class="card-header fw-semibold fs-5 d-flex justify-content-between align-items-center">
        <span>@Overview.UserName</span>
        <div class="d-flex gap-2">
            @{ var lastNight = Overview.Rows.LastOrDefault(r => r.SleepScore.HasValue)?.Day; }
            @if (lastNight.HasValue)
            {
                <a href="night/@Overview.UserName/@lastNight.Value.ToString("yyyy-MM-dd")" class="btn btn-sm btn-primary">Last night →</a>
            }
            <a href="user/@Overview.UserName" class="btn btn-sm btn-outline-secondary">Detail →</a>
        </div>
    </div>
    <div class="card-body">

        @* ── Key stats row ── *@
        <div class="row text-center mb-3 g-2">
            <div class="col">
                <div class="fs-3 fw-bold">@Fmt(AvgScore)</div>
                <div class="text-muted small">Sleep score</div>
            </div>
            <div class="col">
                <div class="fs-3 fw-bold">@Fmt(AvgReadiness)</div>
                <div class="text-muted small">Readiness</div>
            </div>
            <div class="col">
                <div class="fs-3 fw-bold">@Fmt(AvgHrvMs)</div>
                <div class="text-muted small">HRV (ms)</div>
            </div>
            <div class="col">
                <div class="fs-3 fw-bold">@FmtD(AvgHrBpm)</div>
                <div class="text-muted small">Nocturnal HR</div>
            </div>
            <div class="col">
                <div class="fs-3 fw-bold">@FmtD(AvgBreath)</div>
                <div class="text-muted small">Resp (brpm)</div>
            </div>
            <div class="col">
                <div class="fs-3 fw-bold">@Fmt(AvgDeepMin)</div>
                <div class="text-muted small">Deep (min)</div>
            </div>
            <div class="col">
                <div class="fs-3 fw-bold">@Fmt(AvgRemMin)</div>
                <div class="text-muted small">REM (min)</div>
            </div>
        </div>

        @* ── Sleep score sparkline ── *@
        <h6 class="text-muted mb-1">Sleep score</h6>
        <ApexChart TItem="DailyOverviewRow"
                   Options="_scoreOptions"
                   Height="120">
            <ApexPointSeries TItem="DailyOverviewRow"
                             Items="_rows"
                             Name="Score"
                             SeriesType="SeriesType.Line"
                             XValue="r => r.Day.ToDateTime(TimeOnly.MinValue)"
                             YValue="r => r.SleepScore" />
        </ApexChart>

        @* ── HRV line ── *@
        <h6 class="text-muted mt-2 mb-1">HRV (ms)</h6>
        <ApexChart TItem="DailyOverviewRow"
                   Options="_hrvOptions"
                   Height="120">
            <ApexPointSeries TItem="DailyOverviewRow"
                             Items="_rows"
                             Name="HRV"
                             SeriesType="SeriesType.Line"
                             XValue="r => r.Day.ToDateTime(TimeOnly.MinValue)"
                             YValue="r => r.AvgHrv" />
        </ApexChart>

    </div>
</div>

@code {
    [Parameter, EditorRequired] public UserOverview Overview { get; set; } = null!;

    private List<DailyOverviewRow> _rows = [];

    // Aggregates (only days that have data)
    private int? AvgScore     => Avg(_rows.Select(r => (double?)r.SleepScore));
    private int? AvgReadiness => Avg(_rows.Select(r => (double?)r.ReadinessScore));
    private int? AvgHrvMs     => Avg(_rows.Select(r => (double?)r.AvgHrv));
    private double? AvgHrBpm  => _rows.Where(r => r.AvgHr.HasValue).Select(r => r.AvgHr).DefaultIfEmpty().Average();
    private double? AvgBreath => _rows.Where(r => r.AvgBreath.HasValue).Select(r => r.AvgBreath).DefaultIfEmpty().Average();
    private int? AvgDeepMin   => Avg(_rows.Select(r => (double?)r.DeepMinutes));
    private int? AvgRemMin    => Avg(_rows.Select(r => (double?)r.RemMinutes));

    private static int? Avg(IEnumerable<double?> values)
    {
        var v = values.Where(x => x.HasValue).Select(x => x!.Value).ToList();
        return v.Count == 0 ? null : (int)Math.Round(v.Average());
    }

    private static string Fmt(int? v) => v.HasValue ? v.Value.ToString() : "—";
    private static string FmtD(double? v) => v.HasValue ? v.Value.ToString("F0") : "—";

    private ApexChartOptions<DailyOverviewRow> _scoreOptions = null!;
    private ApexChartOptions<DailyOverviewRow> _hrvOptions = null!;

    protected override void OnParametersSet()
    {
        _rows = Overview.Rows;
        _scoreOptions = BuildOptions(0, 100);
        _hrvOptions   = BuildOptions(null, null);
    }

    private static ApexChartOptions<DailyOverviewRow> BuildOptions(int? yMin, int? yMax)
    {
        var opts = new ApexChartOptions<DailyOverviewRow>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = false },
                Sparkline = new ChartSparkline { Enabled = false },
                Background = "transparent",
            },
            Stroke = new Stroke { Curve = Curve.Smooth, Width = [2] },
            Markers = new Markers { Size = [0] },
            Grid = new Grid { BorderColor = "#e0e0e0", Row = new GridRow { Opacity = 0 } },
            Tooltip = new Tooltip { X = new TooltipX { Format = "dd MMM" } },
            Xaxis = new XAxis { Type = XAxisType.Datetime, Labels = new XAxisLabels { Format = "dd MMM" } },
            Yaxis = [new YAxis { Min = yMin, Max = yMax, Labels = new YAxisLabels { MinWidth = 30 } }],
            Legend = new Legend { Show = false },
        };
        return opts;
    }
}
