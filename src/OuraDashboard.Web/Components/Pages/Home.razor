@page "/"
@rendermode InteractiveServer

@inject DashboardQueryService Query

<PageTitle>Overview</PageTitle>

<h1 class="mb-4">Overview — last 30 days</h1>

@if (_loading)
{
    <p><em>Loading…</em></p>
}
else
{
    <div class="row g-4">
        @foreach (var overview in _overviews)
        {
            <div class="col-12 col-xl-6">
                <UserCard Overview="overview" />
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private List<UserOverview> _overviews = [];

    protected override async Task OnInitializedAsync()
    {
        var boo = await Query.GetUserOverviewAsync("Boo", 30);
        var maa = await Query.GetUserOverviewAsync("Maa", 30);
        _overviews = [boo, maa];
        _loading = false;
    }
}
